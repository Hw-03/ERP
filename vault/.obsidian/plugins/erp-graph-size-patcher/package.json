{
  "name": "erp-graph-size-patcher",
  "version": "0.1.0",
  "private": true,
  "description": "Runtime node size patcher for Obsidian's built-in Graph View.",
  "main": "main.js",
  "scripts": {
    "build": "esbuild main.ts --bundle --external:obsidian --format=cjs --platform=browser --target=es2018 --outfile=main.js",
    "check": "tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.0"
  }
}
