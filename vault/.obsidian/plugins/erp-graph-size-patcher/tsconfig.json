{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2018",
    "allowJs": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "lib": [
